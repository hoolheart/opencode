                "baseURL": "http://172.22.240.1:11434/v1"
            },
            "models": {
                "glm-5:cloud": {
                    "name": "glm-5"
                },
                "glm-4.7-flash": {
                    "name": "glm-4.7-flash"
                },
                "gpt-oss": {
                    "name": "gpt-oss"
                },
                "qwen3.5": {
                    "name": "qwen3.5"
                },
            },
        },
    },
}
